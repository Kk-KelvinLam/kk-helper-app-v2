rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Purchase records - users can modify only their own records
    // Read is allowed for the owner or users with a share relationship
    match /purchases/{purchaseId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        exists(/databases/$(database)/documents/shares/$(resource.data.userId + '_' + request.auth.uid))
      );
    }

    // Blood pressure records - users can modify only their own records
    // Read is allowed for the owner or users with a share relationship (only shared records)
    match /bloodPressureRecords/{recordId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        (resource.data.isShared == true && exists(/databases/$(database)/documents/shares/$(resource.data.userId + '_' + request.auth.uid)))
      );
    }

    // Share records - deterministic IDs: {ownerUserId}_{sharedWithUserId}
    match /shares/{shareId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.ownerUserId ||
        request.auth.uid == resource.data.sharedWithUserId
      );
      allow create: if request.auth != null;
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.ownerUserId ||
        request.auth.uid == resource.data.sharedWithUserId
      );
    }
  }
}
