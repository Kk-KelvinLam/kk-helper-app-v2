# Firebase configuration
# Copy this file to .env and fill in the values from your Firebase project settings
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=kk-helper-app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=kk-helper-app
VITE_FIREBASE_STORAGE_BUCKET=kk-helper-app.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# OCR Backend API (Python FastAPI service)
# The app uses the backend for image data extraction by default,
# including ML-based BP monitor image classification.
# Falls back to client-side Tesseract.js when the backend is unavailable.
VITE_OCR_API_URL=http://localhost:8000
